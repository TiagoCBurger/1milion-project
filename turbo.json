{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.test.ts",
        "!**/*.test.tsx",
        "!**/__tests__/**"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "**/__tests__/**", "**/*.test.ts", "**/*.test.tsx"],
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "email:dev": {
      "cache": false,
      "persistent": true
    },
    "email:preview": {
      "cache": false,
      "persistent": true
    }
  }
}
