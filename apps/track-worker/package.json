{
  "name": "@vibefly/track-worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "build:tracker": "tsx src/tracker/build.ts",
    "deploy": "pnpm build:tracker && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@vibefly/shared": "workspace:*",
    "isbot": "^5.1.17",
    "ua-parser-js": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250312.0",
    "@types/ua-parser-js": "^0.7.39",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.0.0"
  }
}
